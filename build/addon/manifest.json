{
  "manifest_version": 2,
  "name": "Zotero Library Bridge",
  "version": "0.2.16",
  "description": "Local Zotero library bridge plugin for import, reading, tagging, and citation workflows",
  "homepage_url": "https://github.com/MuiseDestiny/zotero-figure#readme",
  "author": "Polygon",
  "icons": {
    "48": "chrome/content/icons/favicon@0.5x.png",
    "96": "chrome/content/icons/favicon.png"
  },
  "applications": {
    "zotero": {
      "id": "zotero-library-bridge@polygon.org",
      "update_url": "https://raw.githubusercontent.com/MuiseDestiny/zotero-figure/bootstrap/update.json",
      "strict_min_version": "7.0",
      "strict_max_version": "999.*"
    }
  }
}
